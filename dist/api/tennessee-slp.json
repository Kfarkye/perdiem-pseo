    {
      "@type": "Question",
      "name": "How much does a Tennessee SLP license cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "$165 initial. $115 biennial renewal."
      }
    },
    {
      "@type": "Question",
      "name": "Is Tennessee part of the ASLP Interstate Compact?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes."
      }
    },
    {
      "@type": "Question",
      "name": "Does Tennessee allow telepractice for SLPs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes."
      }
    },
    {
      "@type": "Question",
      "name": "Does Tennessee have reciprocity for speech-language pathologists?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Tennessee participates in the ASLP-IC. If your home state and license qualify for compact privilege, you can typically practice in Tennessee without a separate endorsement application."
      }
    },
    {
      "@type": "Question",
      "name": "How long does it take to transfer my speech-language pathologist license to Tennessee?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most endorsement applications take 2 to 4 weeks. If you qualify for an active compact privilege, there may be no separate wait to start practicing."
      }
    },
    {
      "@type": "Question",
      "name": "Can I start working in Tennessee while my endorsement application is processing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A temporary or provisional credential is available while the full endorsement application is pending."
      }
    }
  ],
