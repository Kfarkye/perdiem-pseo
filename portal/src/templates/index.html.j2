<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, maximum-scale=5.0">
<title>License Transfer by State — Endorsement Fees, Board Links & Timelines (2026)</title>
<meta name="description" content="Find license transfer and endorsement requirements by state for {{ deployed_count }} travel healthcare professions. Compare board links, fees, fingerprinting, and timelines across all 50 states and DC.">
<link rel="canonical" href="{{ domain }}">
<meta name="robots" content="index, follow">
<meta name="theme-color" content="#ffffff">
<meta property="og:title" content="License Transfer by State — Endorsement Fees, Board Links & Timelines (2026)">
<meta property="og:description" content="Compare license transfer steps, fees, fingerprinting, and board links across all 50 states and DC.">
<meta property="og:type" content="website">
<meta property="og:url" content="{{ domain }}">
<meta property="og:image" content="{{ domain }}/social-card.svg">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="License Transfer by State — Endorsement Fees, Board Links & Timelines (2026)">
<meta name="twitter:description" content="Compare license transfer steps, fees, fingerprinting, and board links across all 50 states and DC.">
<meta name="twitter:image" content="{{ domain }}/social-card.svg">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&family=Karla:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #ffffff;
  --paper: #faf9f7;
  --text: #222222;
  --muted: #666666;
  --line: #e5e1db;
  --link: #1a5f7a;
  --focus: rgba(26, 95, 122, 0.2);
  --accent: #b08a52;
  --accent-soft: rgba(176, 138, 82, 0.14);
  --shell: 1120px;
  --reading: 760px;
  --shadow-soft: 0 18px 42px rgba(37, 29, 20, 0.06);
  --shadow-card: 0 16px 34px rgba(37, 29, 20, 0.08);
}

*, *::before, *::after { box-sizing: border-box; }
html { scroll-behavior: smooth; scroll-padding-top: 124px; }
body {
  margin: 0;
  background: var(--bg);
  color: var(--text);
  font-family: 'Karla', -apple-system, BlinkMacSystemFont, sans-serif;
  line-height: 1.65;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}
a {
  color: inherit;
  text-decoration: none;
  transition: color 140ms ease, border-color 140ms ease, background-color 140ms ease, box-shadow 180ms ease, transform 180ms ease;
}
button { font: inherit; border: 0; background: none; cursor: pointer; }
ul { list-style: none; margin: 0; padding: 0; }
h1, h2, h3 {
  font-family: 'Source Serif 4', Georgia, serif;
  letter-spacing: -0.01em;
  line-height: 1.2;
  margin: 0;
  color: #191919;
}
a:focus-visible, button:focus-visible, input:focus-visible {
  outline: 0;
  box-shadow: 0 0 0 3px var(--focus);
}

.site-nav {
  position: sticky;
  top: 0;
  z-index: 100;
  height: 58px;
  display: flex;
  align-items: center;
  border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  box-shadow: 0 1px 0 rgba(255, 255, 255, 0.82);
}
.site-nav-inner {
  width: 100%;
  max-width: var(--shell);
  margin: 0 auto;
  padding: 0 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.site-nav-brand {
  font-size: 13px;
  font-weight: 600;
  color: #555;
}
.site-nav-links {
  display: flex;
  align-items: center;
  gap: 18px;
}
.site-nav-links a {
  font-size: 13px;
  color: #888;
  padding: 6px 0;
  border-bottom: 1px solid transparent;
}
.site-nav-links a:hover {
  color: #333;
  border-color: rgba(176, 138, 82, 0.48);
}

.hero-wrapper {
  max-width: var(--shell);
  margin: 0 auto;
  padding: 92px 24px 56px;
}
.hero-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 44px;
  align-items: stretch;
  min-height: 280px;
}
.hero-copy {
  max-width: 46rem;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}
.hero-kicker {
  margin: 0 0 12px;
  font-size: 12px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #7c7267;
}
.hero-wrapper h1 {
  font-size: clamp(34px, 5vw, 52px);
  margin-bottom: 14px;
}
.hero-sub {
  max-width: 42ch;
  font-size: 19px;
  color: #444;
  margin: 0;
}

.search-wrap {
  max-width: var(--shell);
  margin: 0 auto;
  padding: 0 24px;
}
.search-inner {
  border: 1px solid var(--line);
  border-radius: 22px;
  background: #fff;
  padding: 16px;
  box-shadow: var(--shadow-soft);
}
.search-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18px;
}
.search-panel {
  border: 1px solid rgba(0, 0, 0, 0.06);
  border-radius: 18px;
  padding: 16px;
  background: #fff;
}
.search-copy {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 12px;
}
.search-title {
  font-size: 14px;
  font-weight: 600;
  color: #2b2b2b;
}
.search-note {
  font-size: 13px;
  color: #7c7267;
}
.search-field {
  min-width: 0;
  position: relative;
  display: flex;
  align-items: center;
}
.search-actions {
  display: flex;
  gap: 10px;
  align-items: center;
}
.search-actions-stacked {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 10px;
  align-items: center;
}
.search-icon {
  position: absolute;
  left: 12px;
  color: #999;
  pointer-events: none;
}
.search-input {
  width: 100%;
  height: 44px;
  border: 1px solid var(--line);
  border-radius: 12px;
  padding: 0 38px;
  font-size: 15px;
  font-family: inherit;
  color: var(--text);
  background: #fff;
}
.search-input::placeholder { color: #999; }
.search-select {
  width: 100%;
  height: 44px;
  border: 1px solid var(--line);
  border-radius: 12px;
  padding: 0 40px 0 12px;
  font-size: 15px;
  font-family: inherit;
  color: var(--text);
  background: #fff;
  appearance: none;
  -webkit-appearance: none;
  background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1L5 5L9 1' stroke='%23888' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
  background-repeat: no-repeat;
  background-position: right 12px center;
}
.search-submit {
  height: 44px;
  padding: 0 16px;
  border-radius: 12px;
  background: #191919;
  color: #fff;
  font-size: 14px;
  font-weight: 600;
  white-space: nowrap;
}
.search-submit:disabled {
  cursor: not-allowed;
  opacity: 0.4;
}
.search-clear {
  position: absolute;
  right: 9px;
  width: 22px;
  height: 22px;
  display: none;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  border: 1px solid var(--line);
  color: #999;
  background: #fff;
}
.search-examples {
  margin: 12px 0 0;
  font-size: 13px;
  color: #7f766b;
}
.search-examples a {
  color: #4a4641;
  text-decoration: underline;
  text-decoration-color: rgba(176, 138, 82, 0.28);
  text-underline-offset: 3px;
}
.search-examples a:hover {
  text-decoration-color: rgba(176, 138, 82, 0.7);
}

.content {
  max-width: var(--shell);
  margin: 34px auto 0;
  padding: 0 24px 72px;
}
.feature-shell {
  margin-bottom: 34px;
}
.directory-shell {
  border: 1px solid var(--line);
  border-radius: 28px;
  background: var(--paper);
  overflow: hidden;
  box-shadow: var(--shadow-soft);
}
.directory-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12px;
  padding: 20px 24px 18px;
  border-bottom: 1px solid rgba(0, 0, 0, 0.06);
}
.section-kicker {
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #7c7267;
  margin: 0 0 12px;
}
.grid-title {
  font-size: 11px;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: #777;
  margin: 0;
}
.directory-note {
  font-size: 13px;
  color: #7c7267;
}

.profession-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0;
  background: rgba(255, 255, 255, 0.72);
}
.profession-card {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 20px;
  gap: 12px;
  align-items: center;
  min-height: 116px;
  padding: 24px 26px 22px;
  border-top: 1px solid rgba(0, 0, 0, 0.06);
  background: transparent;
}
.profession-card:hover {
  background: rgba(255, 255, 255, 0.72);
}
.profession-card:nth-child(odd) {
  border-right: 1px solid rgba(0, 0, 0, 0.06);
}
.profession-card:nth-child(-n+2) {
  border-top: 0;
}

.card-body {
  min-width: 0;
}
.card-title {
  font-size: 22px;
  font-weight: 600;
  margin: 0;
}
.card-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
  margin: 8px 0 0;
  font-size: 14px;
  color: #5f5a53;
}
.card-meta-divider {
  color: #b0a79d;
}
.card-chevron {
  display: flex;
  justify-content: flex-end;
  color: #9a9a9a;
  align-self: center;
}

.empty-state {
  display: none;
  border: 1px solid var(--line);
  border-radius: 18px;
  background: var(--paper);
  padding: 32px 20px;
  text-align: center;
  margin-top: 12px;
  box-shadow: var(--shadow-soft);
}
.empty-state h3 { font-size: 22px; margin: 0 0 6px; }
.empty-state p { margin: 0; color: #666; }

.features {
  margin-top: 44px;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 18px;
}
.feature-card {
  background: var(--paper);
  border: 1px solid var(--line);
  border-radius: 22px;
  padding: 24px 24px 22px;
  box-shadow: var(--shadow-soft);
}
.feature-card h3 {
  font-size: 20px;
  margin: 0 0 6px;
}
.feature-card p {
  margin: 0;
  font-size: 15px;
  color: #555;
}

.foot-wrapper {
  border-top: 1px solid var(--line);
  padding: 44px 24px 60px;
}
.foot {
  max-width: var(--shell);
  margin: 0 auto;
  display: grid;
  grid-template-columns: 2fr 1fr;
  gap: 48px;
}
.foot h2 {
  font-family: 'Source Serif 4', Georgia, serif;
  font-size: 20px;
  margin: 0 0 8px;
}
.foot p {
  font-size: 14px;
  color: #666;
  margin: 0;
}
.foot-links { display: grid; gap: 8px; }
.foot-links a {
  font-size: 14px;
  color: var(--link);
  text-decoration: underline;
  text-decoration-color: rgba(26, 95, 122, 0.3);
}
.foot-meta {
  display: block;
  margin-top: 12px;
  font-size: 12px;
  color: #999;
}

@media (max-width: 760px) {
  .site-nav-links { display: none; }
  .hero-wrapper { padding: 46px 16px 28px; }
  .site-nav-inner,
  .search-wrap,
  .content,
  .foot-wrapper {
    padding-left: 16px;
    padding-right: 16px;
  }
  .hero-grid {
    grid-template-columns: 1fr;
    gap: 20px;
    min-height: 0;
  }
  .hero-copy {
    justify-content: flex-start;
  }
  .hero-actions {
    gap: 10px 14px;
  }
  .directory-head {
    display: block;
    padding: 18px 16px 14px;
  }
  .directory-note {
    display: block;
    margin-top: 4px;
  }
  .profession-card {
    grid-template-columns: minmax(0, 1fr) 20px;
    gap: 10px;
    min-height: 0;
    padding: 18px 16px;
  }
  .profession-grid { grid-template-columns: 1fr; }
  .profession-card:nth-child(odd) {
    border-right: 0;
  }
  .profession-card:nth-child(2) {
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }
  .card-chevron {
    align-self: center;
  }
  .search-copy {
    display: block;
  }
  .search-note {
    display: block;
    margin-top: 4px;
  }
  .search-grid {
    grid-template-columns: 1fr;
  }
  .search-actions,
  .search-actions-stacked {
    grid-template-columns: 1fr;
    flex-direction: column;
    align-items: stretch;
  }
  .features { grid-template-columns: 1fr; }
  .foot { grid-template-columns: 1fr; }
}
</style>
</head>
<body>
<nav class="site-nav" aria-label="Site navigation">
  <div class="site-nav-inner">
    <a href="{{ domain }}/" class="site-nav-brand">State Licensing Reference</a>
    <div class="site-nav-links">
      <a href="#specialty-jump">Specialties</a>
    </div>
  </div>
</nav>

<header class="hero-wrapper">
  <div class="hero-grid">
    <div class="hero-copy">
      <p class="hero-kicker">Licensing Hub</p>
      <h1>State-by-state licensing requirements.</h1>
    </div>
  </div>
</header>

<div class="search-wrap" id="search">
  <div class="search-inner">
    <div class="search-grid">
      <section class="search-panel" id="specialty-jump" aria-label="Choose specialty">
        <div class="search-actions-stacked">
          <select id="specialtySelect" class="search-select" aria-label="Choose specialty">
            {% for card in cards %}
            <option value="{{ card.slug }}">{{ card.title_full }}</option>
            {% endfor %}
          </select>
          <button id="specialtyOpenButton" class="search-submit" type="button">Open specialty</button>
        </div>
      </section>
    </div>
  </div>
</div>

<div class="foot-wrapper">
  <footer class="foot">
    <div>
      <h2>About This Hub</h2>
      <p>State Licensing Reference is an independent reference for state licensing requirements across the United States.</p>
      <span class="foot-meta">Updated &bull; {{ today }}</span>
    </div>
  </footer>
</div>

<script>
const specialtySelect = document.getElementById('specialtySelect');
const specialtyOpenButton = document.getElementById('specialtyOpenButton');

specialtyOpenButton.addEventListener('click', () => {
  const slug = specialtySelect.value;
  if (!slug) return;
  window.location.href = `${window.location.origin}/${slug}`;
});
</script>
</body>
</html>
